    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object"
    },
    "property": {
      "type": "object"
    },
    "homeowner": {
      "type": "object"
    },
    "inspection": {
      "type": "object"
    },
    "original_report": {
      "type": "object"
    },
    "processing": {
      "type": "object"
    },
    "standard_findings": {
      "type": "array"
    },
    "audit": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
