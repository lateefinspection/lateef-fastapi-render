imponrt re
from .base_adapter import BaseAdapter


class SectionBasedAdapter(BaseAdapter):
    name = "section_based"
    SUMMARY_PAGES = []

    SECTION_HEADERS = [
        "roof",
        "roofing",
        "exterior",
        "interior",
        "electrical",
        "plumbing",
        "heating",
        "cooling",
        "hvac",
        "foundation",
        "structure",
        "structural",
        "attic",
        "insulation",
        "basement",
        "garage",
        "windows",
        "doors",
        "kitchen",
        "bathroom",
        "bathrooms",
        "appliances",
        "fireplace",
        "grading",
        "drainage",
        "deck",
        "porch",
        "stairs",
        "chimney",
        "water heater",
        "laundry",
        "foundation area",
        "heating & cooling components",
        "interior areas and items",
        "attic, roof structure, & ventilation",
        "water, moisture, & condensation",
        "cracking, settlement, & movement",
    ]

    ISSUE_HINTS = [
        "damage",
        "damaged",
        "defect",
        "defective",
        "missing",
        "loose",
        "unsafe",
        "hazard",
        "leak",
        "leaking",
        "moisture",
        "crack",
        "cracked",
        "rot",
        "rotted",
        "deteriorated",
        "inadequate",
        "not functional",
        "not working",
        "recommend",
        "repair",
        "replace",
        "service",
        "monitor",
        "further evaluation",
        "qualified contractor",
        "qualified professional",
        "contractor",
        "electrician",
        "plumber",
        "roofer",
        "hvac professional",
        "handyman",
        "water intrusion",
        "settlement",
        "movement",
        "corrosion",
        "rust",
        "trip hazard",
        "fall hazard",
        "safety",
        "improper",
        "unsupported",
        "blocked",
        "staining",
        "active leak",
        "double tapped",
        "gfci",
        "not present",
        "not installed",
        "recommendation",
    ]

    BULLET_RE = re.compile(r"^\s*(?:[-*•]|\d+[.)])\s+(.+)$")
    COLON_HEADER_RE = re.compile(r"^\s*([A-Za-z][A-Za-z &/\-(),]{2,60})\s*:\s*$")
    SHORT_HEADER_RE = re.compile(r"^[A-Z][A-Za-z &/\-(),]{2,60}$")

    def normalize_section_name(self, text: str) -> str:
        text = re.sub(r"\s+", " ", text.strip())
        return text.title()

    def looks_like_section_header(self, line: str) -> bool:
        s = line.strip()
        if not s:
            return False

        lower = s.lower().strip(":")
        if lower in self.SECTION_HEADERS:
            return True

        colon_match = self.COLON_HEADER_RE.match(s)
        if colon_match:
            header = colon_match.group(1).strip().lower()
            return header in self.SECTION_HEADERS

        if self.SHORT_HEADER_RE.match(s):
            return lower in self.SECTION_HEADERS

        return False

    def extract_header_name(self, line: str) -> str:
        s = line.strip()
        colon_match = self.COLON_HEADER_RE.match(s)
        if colon_match:
            return self.normalize_section_name(colon_match.group(1))
        return self.normalize_section_name(s.strip(":"))

    def line_looks_like_issue(self, line: str) -> bool:
        s = line.strip()
        if not s:
        return False

    # Remove bullets
        bullet_match = self.BULLET_RE.match(s)
        if bullet_match:
        s = bullet_match.group(1).strip()

        lower = s.lower()

    # 🚫 Reject TOC style like "3.1.2 Grounds - ..."
        if re.match(r"^\d+(\.\d+)+\s", s):
        return False

    # 🚫 Reject numbered headers like "16: Something"
    if re.match(r"^\d{1,2}[:.)]\s+[A-Za-z]", s):
        return False

    # 🚫 Reject very short lines
    if len(s.split()) < 4:
        return False

    # 🚫 Reject non-defect phrases
    noise_patterns = [
        "table of contents",
        "standards of practice",
        "inspection information",
        "utility shutoff",
        "final checklist",
        "buyer name",
        "inspection report",
        "these summary pages are not",
        "read the complete report",
        "contact your real estate agent",
        "for information regarding",
    ]
    if any(p in lower for p in noise_patterns):
        return False

    # 🚫 Reject section headers
    if self.looks_like_section_header(s):
        return False

    # ✅ REQUIRE strong defect language
    strong_signals = [
        "damage",
        "damaged",
        "missing",
        "crack",
        "cracked",
        "leak",
        "leaking",
        "water damage",
        "rot",
        "rotted",
        "defect",
        "unsafe",
        "hazard",
        "not functional",
        "not working",
        "improper",
        "loose",
        "unsupported",
        "corrosion",
        "staining",
        "recommend",
        "repair",
        "replace",
    ]

    if any(signal in lower for signal in strong_signals):
        return True

    return False
        # Reject page-number only or tiny fragments
        if len(s.split()) < 3:
            return False

        if len(lower) < 15:
            return False

        # Reject obvious non-issue document noise
        noise_patterns = [
            "table of contents",
            "standards of practice",
            "inspection information",
            "utility shutoff locations",
            "final checklist",
            "buyer name",
            "professional home inspections",
            "inspection report",
        ]
        if any(p in lower for p in noise_patterns):
            return False

        # Reject clean section headers
        if self.looks_like_section_header(s):
            return False

        # Must contain a defect-like signal
        if any(hint in lower for hint in self.ISSUE_HINTS):
            if len(lower.split()) >= 4:
                return True

        # Common narrative defect phrases
        narrative_patterns = [
            "was observed",
            "was noted",
            "is missing",
            "is damaged",
            "appears damaged",
            "shows signs",
            "needs repair",
            "should be repaired",
            "should be replaced",
            "recommended",
            "further evaluation",
            "contact a qualified",
            "signs of moisture",
            "evidence of",
            "noted at the time of inspection",
        ]
        if any(phrase in lower for phrase in narrative_patterns):
            return True

        return False

    def make_component(self, issue_text: str) -> str:
        text = issue_text.strip()
        if not text:
            return "General"

        text = re.sub(r"^\s*(?:[-*•]|\d+[.)])\s+", "", text).strip()
        first = re.split(r"[,:.;-]", text)[0].strip()

        words = first.split()
        if not words:
            return "General"

        component = " ".join(words[:4]).strip()
        return component.title() if component else "General"

    def make_issue_title(self, issue_text: str) -> str:
        text = re.sub(r"^\s*(?:[-*•]|\d+[.)])\s+", "", issue_text).strip()
        text = re.sub(r"\s+", " ", text)
        return text[:140].strip()

    def extract_summary_issues(self, pages):
        issues = []
        current_section = "General"
        section_index = 1
        issue_counter = 1

        for page in pages:
            page_number = page.get("page_number")
            text = page.get("text", "")

            # Skip table of contents pages
            lower_text = text.lower()
            if "table of contents" in lower_text:
                continue

            lines = text.splitlines()

            for raw_line in lines:
                line = raw_line.strip()
                if not line:
                    continue

                if self.looks_like_section_header(line):
                    current_section = self.extract_header_name(line)
                    section_index += 1
                    issue_counter = 1
                    continue

                if not self.line_looks_like_issue(line):
                    continue

                issue_code = f"S{section_index}.{issue_counter}"
                issue_counter += 1

                issues.append({
                    "issue_code": issue_code,
                    "system": current_section,
                    "component": self.make_component(line),
                    "issue_title": self.make_issue_title(line),
                    "summary_page": page_number,
                })

        # Deduplicate by normalized title + section
        seen = set()
        deduped = []
        for issue in issues:
            key = (
                issue["system"].strip().lower(),
                issue["issue_title"].strip().lower(),
            )
            if key in seen:
                continue
            seen.add(key)
            deduped.append(issue)

        return deduped

    def extract_detail(self, issue_code, pages):
        """
        For section-based reports, we do not have a clean code-to-detail mapping.
        Use the summary page and issue title match as best effort.
        """
        target_issue = None
        extracted_issues = self.extract_summary_issues(pages)
        for issue in extracted_issues:
            if issue["issue_code"] == issue_code:
                target_issue = issue
                break

        if not target_issue:
            return None, "", ""

        summary_page = target_issue.get("summary_page")
        issue_title = target_issue.get("issue_title", "").lower()

        candidate_pages = []
        if summary_page:
            candidate_pages.append(summary_page)
            candidate_pages.append(summary_page + 1)

        for page_number in candidate_pages:
            page = self.get_page_by_number(pages, page_number)
            if not page:
                continue

            text = self.clean_text_block(page.get("text", ""))
            if issue_title and issue_title[:40] in text.lower():
                recommendation = self.extract_recommendation(text)
                return page_number, text, recommendation

        for page in pages:
            text = self.clean_text_block(page.get("text", ""))
            if issue_title and issue_title[:40] in text.lower():
                recommendation = self.extract_recommendation(text)
                return page.get("page_number"), text, recommendation

        page = self.get_page_by_number(pages, summary_page) if summary_page else None
        if page:
            text = self.clean_text_block(page.get("text", ""))
            recommendation = self.extract_recommendation(text)
            return summary_page, text, recommendation

        return None, "", ""

    def extract_recommendation(self, text: str) -> str:
        text = text.strip()

        patterns = [
            r"recommended action[:\s]+(.+?)(?:\n|$)",
            r"recommend(?:ed)?[:\s]+(.+?)(?:\n|$)",
            r"should be repaired[:\s]*(.+?)(?:\n|$)",
            r"should be replaced[:\s]*(.+?)(?:\n|$)",
            r"(contact a qualified .+?)(?:\.|$)",
        ]

        for pattern in patterns:
            match = re.search(pattern, text, re.IGNORECASE)
            if match:
                value = match.group(1).strip() if match.groups() else match.group(0).strip()
                return self.clean_recommendation(value)

        lower = text.lower()
        if "electric" in lower:
            return "Contact a qualified electrician."
        if "plumb" in lower:
            return "Contact a qualified plumbing contractor."
        if "roof" in lower:
            return "Contact a qualified roofing contractor."
        if "hvac" in lower or "heating" in lower or "cooling" in lower:
            return "Contact a qualified HVAC professional."

        return "Further evaluation recommended."
